# ============================================================
# SUPABASE CONFIGURATION
# Get these from: https://supabase.com → Your Project → Settings → API
# ============================================================

# Your Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key (safe to expose in frontend)
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (SECRET - backend only, never expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# APP CONFIGURATION
# ============================================================

# JWT secret for signing tokens (generate a strong random string)
JWT_SECRET=your-very-strong-random-secret-here

# Node environment
NODE_ENV=development

# Port for local development
PORT=3000

# Frontend URL (for CORS - update to your Vercel URL in production)
FRONTEND_URL=http://localhost:8080
