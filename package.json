{
  "name": "rwanda-trad-ecommerce",
  "version": "1.0.0",
  "description": "Rwanda Traditional Attire E-Commerce Platform - Full Stack with Supabase and Vercel",
  "main": "api/server.js",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand --forceExit",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "lint": "eslint api/**/*.js tests/**/*.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "collectCoverageFrom": [
      "api/**/*.js",
      "!api/_lib/supabase.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Rwanda Trad",
  "license": "MIT"
}
